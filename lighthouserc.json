{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": ["http://localhost/"],
      "numberOfRuns": 3,
      "settings": {
        "throttlingMethod": "devtools"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9 }],
        "categories:accessibility": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["warn", { "minScore": 0.9 }],
        "bf-cache": "off",
        "dom-size": "off",
        "third-party-facades": "off",
        "redirects": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
